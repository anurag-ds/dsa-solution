class Solution {
public:
    int subarraySum(vector<int>& nums, int k) {
        int n = nums.size();
        unordered_map<int, int> prefixSumCount;
        prefixSumCount[0] =1;
        int prefixsum =0;
        int cnt = 0;

        for(int i =0; i<n; i++){
            prefixsum += nums[i];

            int remove = prefixsum -k;

            if(prefixSumCount.find(remove) != prefixSumCount.end()){
                cnt += prefixSumCount[remove];
            }
        prefixSumCount[prefixsum]++;
        }
        return cnt;
    }
};
